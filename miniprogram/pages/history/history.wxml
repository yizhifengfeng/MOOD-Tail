<view class="page">
  <!-- Custom nav -->
  <view class="nav-wrap" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar glass" style="min-height: {{navContentHeight}}px;">
      <view class="nav-bar__row">
        <view class="nav-bar__left">
          <view class="nav-back" bindtap="goBack" hover-class="nav-back--active" aria-label="返回">‹</view>
          <text class="nav-brand">MOOD Tail</text>
        </view>
        <text class="nav-slogan">MOOD Tail・按心情・喝一杯</text>
      </view>
    </view>
  </view>

  <view class="main" style="padding-top: {{mainPadTop}}px;">
    <!-- Tabs -->
    <view class="tabs-wrap">
      <view class="tabs glass">
        <view
          class="tabs__pill {{activeTab === 0 ? 'tabs__pill--active' : ''}}"
          data-index="0"
          bindtap="switchTab"
        >我的酒单</view>
        <view
          class="tabs__pill {{activeTab === 1 ? 'tabs__pill--active' : ''}}"
          data-index="1"
          bindtap="switchTab"
        >心情日历</view>
      </view>
    </view>

    <!-- Tab 1: list -->
    <view wx:if="{{activeTab === 0}}" class="panel panel--list">
      <view wx:if="{{loading}}" class="state state--loading">
        <text class="state__text">加载中…</text>
      </view>

      <block wx:elif="{{cocktailList.length}}">
        <view class="section-title">情绪特调</view>
        <scroll-view scroll-y class="list-scroll" show-scrollbar="{{false}}">
          <view
            wx:for="{{cocktailList}}"
            wx:key="rowKey"
            class="menu-card glass"
            data-id="{{item.id}}"
            mark:cid="{{item.id}}"
            bindtap="onListItemTap"
          >
            <view class="menu-card__accent menu-card__accent--{{item.direction}}" />
            <view class="menu-card__dot menu-card__dot--{{item.direction}}" />
            <view class="menu-card__body">
              <view class="menu-card__row1">
                <text class="menu-card__name">{{item.name}}</text>
                <view
                  class="menu-card__del"
                  data-id="{{item.id}}"
                  catchtap="onDeleteItem"
                  aria-label="删除"
                >×</view>
              </view>
              <view class="menu-card__row2">
                <text class="menu-card__time">{{item.displayTime}}</text>
                <text class="badge badge--{{item.direction}}">{{item.badge}}</text>
              </view>
            </view>
          </view>
          <view class="list-pad" />
        </scroll-view>
      </block>

      <view wx:else class="empty">
        <view class="empty__art" aria-hidden="true">
          <text class="empty__emoji">🍸</text>
          <view class="empty__rings" />
        </view>
        <text class="empty__title">还没有保存的特调</text>
        <text class="empty__hint">调一杯心情，它会出现在这里</text>
      </view>
    </view>

    <!-- Tab 2: calendar -->
    <view wx:if="{{activeTab === 1}}" class="panel panel--calendar">
      <view class="calendar-shell glass">
        <mood-calendar moodData="{{moodData}}" binddatetap="onCalendarDateTap" />
      </view>
    </view>
  </view>

  <!-- Calendar preview -->
  <view wx:if="{{previewVisible}}" class="preview-mask" bindtap="onPreviewMaskTap">
    <view class="preview-sheet {{previewAnim ? 'preview-sheet--in' : ''}}" catchtap="">
      <view class="preview-sheet__handle" />
      <block wx:if="{{selectedDateCocktail}}">
        <view class="preview-sheet__accent preview-sheet__accent--{{selectedDateCocktail.direction}}" />
        <text class="preview-sheet__label">当日特调</text>
        <text class="preview-sheet__name">{{selectedDateCocktail.name}}</text>
        <view class="preview-sheet__row">
          <text class="badge badge--{{selectedDateCocktail.direction}}">{{selectedDateCocktail.badge}}</text>
          <text class="preview-sheet__time">{{selectedDateCocktail.displayTime}}</text>
        </view>
        <button
          class="btn btn-secondary preview-sheet__btn"
          data-id="{{selectedDateCocktail.id}}"
          bindtap="onPreviewGoDetail"
        >查看详情</button>
      </block>
    </view>
  </view>

  <!-- Recommend modal -->
  <view wx:if="{{recommendVisible}}" class="modal-mask" bindtap="closeRecommend">
    <view class="modal-card glass" catchtap="">
      <view class="modal-card__head">
        <text class="modal-card__title">为你推荐</text>
        <text class="modal-card__close" bindtap="closeRecommend">×</text>
      </view>
      <view wx:if="{{recommendLoading}}" class="modal-card__body">
        <text class="state__text">生成中…</text>
      </view>
      <view wx:elif="{{recommendError}}" class="modal-card__body">
        <text class="modal-card__err">{{recommendError}}</text>
      </view>
      <scroll-view wx:else scroll-y class="modal-card__scroll" show-scrollbar="{{false}}">
        <text wx:for="{{recommendLines}}" wx:key="*this" class="modal-card__line">{{item}}</text>
      </scroll-view>
    </view>
  </view>

  <!-- Bottom actions -->
  <view class="bottom-bar glass safe-bottom">
    <button class="btn btn-secondary bottom-bar__btn" bindtap="fetchRecommendations">查看推荐</button>
    <button class="btn btn-secondary bottom-bar__btn" bindtap="goProducts">酒吧产品</button>
  </view>
</view>
