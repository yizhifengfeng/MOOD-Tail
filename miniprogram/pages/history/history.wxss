/* MOOD Tail — History / 酒单 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a0a0f 0%, #12121c 45%, #0a0a0f 100%);
  box-sizing: border-box;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

/* Nav */
.nav-wrap {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-bar {
  padding: 0 24rpx 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.nav-bar__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
}

.nav-bar__left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  color: rgba(255, 255, 255, 0.85);
  border-radius: 50%;
  margin-right: 4rpx;
}

.nav-back--active {
  background: rgba(255, 255, 255, 0.08);
}

.nav-brand {
  font-family: Georgia, 'Noto Serif SC', serif;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  color: var(--color-text-primary, #eaeaea);
}

.nav-slogan {
  font-size: 20rpx;
  color: var(--color-text-hint, #5a5a6e);
  max-width: 52%;
  text-align: right;
  line-height: 1.35;
}

/* Main offset handled inline; content */
.main {
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 24rpx;
}

/* Tabs */
.tabs-wrap {
  margin-bottom: 28rpx;
}

.tabs {
  display: flex;
  padding: 8rpx;
  border-radius: 999rpx;
  gap: 8rpx;
}

.tabs__pill {
  flex: 1;
  text-align: center;
  padding: 18rpx 12rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary, #8b8b9e);
  border-radius: 999rpx;
  transition: background 0.25s ease, color 0.25s ease;
}

.tabs__pill--active {
  background: rgba(168, 85, 247, 0.22);
  color: #fff;
  font-weight: 500;
}

/* Panels */
.panel--list {
  min-height: 50vh;
}

.section-title {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: var(--color-text-hint, #5a5a6e);
  margin-bottom: 20rpx;
}

.list-scroll {
  max-height: calc(100vh - 420rpx);
}

.list-pad {
  height: 24rpx;
}

/* Menu cards */
.menu-card {
  position: relative;
  display: flex;
  align-items: stretch;
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  padding: 28rpx 28rpx 28rpx 20rpx;
}

.menu-card__accent {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  border-radius: 20rpx 0 0 20rpx;
}

.menu-card__accent--bright {
  background: linear-gradient(180deg, #ff9f43, #feca57);
}

.menu-card__accent--calm {
  background: linear-gradient(180deg, #4ecdc4, #48dbfb);
}

.menu-card__accent--deep {
  background: linear-gradient(180deg, #a855f7, #6c5ce7);
}

.menu-card__dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin: 10rpx 20rpx 0 12rpx;
  flex-shrink: 0;
  box-shadow: 0 0 16rpx rgba(255, 255, 255, 0.15);
}

.menu-card__dot--bright {
  background: #ff9f43;
}

.menu-card__dot--calm {
  background: #4ecdc4;
}

.menu-card__dot--deep {
  background: #a855f7;
}

.menu-card__body {
  flex: 1;
  min-width: 0;
}

.menu-card__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.menu-card__name {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text-primary, #eaeaea);
  flex: 1;
}

.menu-card__time {
  font-size: 24rpx;
  color: var(--color-text-secondary, #8b8b9e);
}

.badge {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.9);
  flex-shrink: 0;
}

.badge--bright {
  background: rgba(255, 159, 67, 0.15);
  border-color: rgba(255, 159, 67, 0.35);
  color: #ff9f43;
}

.badge--calm {
  background: rgba(78, 205, 196, 0.15);
  border-color: rgba(78, 205, 196, 0.35);
  color: #4ecdc4;
}

.badge--deep {
  background: rgba(168, 85, 247, 0.15);
  border-color: rgba(168, 85, 247, 0.35);
  color: #a855f7;
}

/* Empty */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx 120rpx;
}

.empty__art {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty__emoji {
  font-size: 96rpx;
  z-index: 1;
}

.empty__rings {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(168, 85, 247, 0.25);
  animation: emptyPulse 3s ease-in-out infinite;
}

@keyframes emptyPulse {
  0%,
  100% {
    transform: scale(1);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.08);
    opacity: 1;
  }
}

.empty__title {
  font-size: 30rpx;
  color: var(--color-text-secondary, #8b8b9e);
  margin-bottom: 12rpx;
}

.empty__hint {
  font-size: 26rpx;
  color: var(--color-text-hint, #5a5a6e);
}

.state--loading {
  padding: 80rpx 0;
  text-align: center;
}

.state__text {
  font-size: 28rpx;
  color: var(--color-text-secondary, #8b8b9e);
}

/* Calendar */
.panel--calendar {
  width: 100%;
}

.calendar-shell {
  border-radius: 24rpx;
  padding: 8rpx 8rpx 20rpx;
  overflow: hidden;
}

/* Preview sheet */
.preview-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.preview-sheet {
  width: 100%;
  max-height: 55vh;
  background: rgba(22, 22, 35, 0.96);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 40rpx calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
}

.preview-sheet--in {
  transform: translateY(0);
}

.preview-sheet__handle {
  width: 64rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 8rpx;
  margin: 0 auto 24rpx;
}

.preview-sheet__accent {
  height: 6rpx;
  width: 120rpx;
  border-radius: 6rpx;
  margin-bottom: 20rpx;
}

.preview-sheet__accent--bright {
  background: #ff9f43;
}

.preview-sheet__accent--calm {
  background: #4ecdc4;
}

.preview-sheet__accent--deep {
  background: #a855f7;
}

.preview-sheet__label {
  font-size: 22rpx;
  color: var(--color-text-hint, #5a5a6e);
  letter-spacing: 2rpx;
}

.preview-sheet__name {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  margin: 12rpx 0 20rpx;
  color: var(--color-text-primary, #eaeaea);
}

.preview-sheet__row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.preview-sheet__time {
  font-size: 26rpx;
  color: var(--color-text-secondary, #8b8b9e);
}

.preview-sheet__btn {
  width: 100% !important;
  margin: 0;
}

/* Recommend modal */
.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 300;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.modal-card {
  width: 100%;
  max-height: 60vh;
  border-radius: 24rpx;
  padding: 28rpx 32rpx 32rpx;
  box-sizing: border-box;
}

.modal-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.modal-card__title {
  font-size: 34rpx;
  font-weight: 600;
}

.modal-card__close {
  font-size: 44rpx;
  color: var(--color-text-secondary, #8b8b9e);
  padding: 8rpx 16rpx;
}

.modal-card__body {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-card__err {
  color: var(--color-danger, #ff6b6b);
  font-size: 28rpx;
}

.modal-card__scroll {
  max-height: 44vh;
}

.modal-card__line {
  display: block;
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--color-text-secondary, #8b8b9e);
  margin-bottom: 16rpx;
}

/* Bottom bar */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  display: flex;
  gap: 20rpx;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.bottom-bar__btn {
  flex: 1;
  margin: 0;
  height: 88rpx !important;
  line-height: 88rpx !important;
  font-size: 28rpx !important;
}

.glass {
  background: rgba(26, 26, 46, 0.55);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}
