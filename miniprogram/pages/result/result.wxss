.page {
  min-height: 100vh;
  background: radial-gradient(120% 80% at 50% 0%, #16161f 0%, #0a0a0f 45%, #060608 100%);
  color: rgba(255, 255, 255, 0.92);
  --accent: #4ecdc4;
  --accent-rgb: 78, 205, 196;
}

.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  box-sizing: border-box;
  background: linear-gradient(180deg, rgba(10, 10, 15, 0.94) 0%, rgba(10, 10, 15, 0.72) 70%, transparent 100%);
  backdrop-filter: blur(20rpx);
}

.nav__inner {
  height: 100%;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.nav__btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.nav__icon {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1;
}

.nav__icon--close {
  font-size: 44rpx;
  font-weight: 300;
  margin-top: -4rpx;
}

.nav__spacer {
  flex: 1;
}

.scroll {
  height: 100vh;
  box-sizing: border-box;
}

.scroll__pad {
  padding: 0 40rpx 280rpx;
}

.scroll__bottom-spacer {
  height: 40rpx;
}

/* Hero typography */
.hero {
  text-align: center;
  padding: 24rpx 0 32rpx;
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 0.9s ease, transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
}

.hero--visible {
  opacity: 1;
  transform: translateY(0);
}

.hero__title {
  display: block;
  font-family: 'Songti SC', 'STSong', 'Noto Serif SC', serif;
  font-size: 52rpx;
  font-weight: 500;
  letter-spacing: 0.12em;
  line-height: 1.35;
  color: rgba(250, 250, 252, 0.96);
}

.hero__en {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  font-style: italic;
  color: rgba(255, 255, 255, 0.42);
  letter-spacing: 0.08em;
}

.emotion-line {
  text-align: center;
  margin-bottom: 16rpx;
}

.emotion-line__text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.38);
  letter-spacing: 0.06em;
}

/* Visual block */
.viz {
  margin-top: 8rpx;
}

.viz__tabs {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.viz__tab {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.45);
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  transition: color 0.25s ease, background 0.25s ease, border-color 0.25s ease;
}

.viz__tab--on {
  color: rgba(255, 255, 255, 0.95);
  background: rgba(var(--accent-rgb), 0.18);
  border-color: rgba(var(--accent-rgb), 0.45);
  box-shadow: 0 0 40rpx rgba(var(--accent-rgb), 0.15);
}

.viz__stage {
  height: 500rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.viz__panel {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.viz__panel--fluid {
  overflow: hidden;
  border-radius: 32rpx;
}

/* —— Glass bottle —— */
.bottle {
  position: relative;
  width: 200rpx;
  height: 420rpx;
  filter: drop-shadow(0 24rpx 48rpx rgba(0, 0, 0, 0.45));
}

.bottle__neck {
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  width: 72rpx;
  height: 56rpx;
  border-radius: 12rpx 12rpx 4rpx 4rpx;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.12) 0%,
    rgba(255, 255, 255, 0.35) 45%,
    rgba(255, 255, 255, 0.1) 100%
  );
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  box-shadow: inset 0 0 24rpx rgba(255, 255, 255, 0.15);
}

.bottle__body {
  position: absolute;
  left: 50%;
  top: 52rpx;
  transform: translateX(-50%);
  width: 200rpx;
  height: 300rpx;
  border-radius: 28rpx 28rpx 36rpx 36rpx;
  background: linear-gradient(
    100deg,
    rgba(255, 255, 255, 0.08) 0%,
    rgba(255, 255, 255, 0.22) 38%,
    rgba(255, 255, 255, 0.06) 58%,
    rgba(255, 255, 255, 0.12) 100%
  );
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  overflow: hidden;
  box-shadow:
    inset 8rpx 0 24rpx rgba(255, 255, 255, 0.12),
    inset -12rpx 0 32rpx rgba(0, 0, 0, 0.2);
}

.bottle__liquid {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 8rpx;
  height: 62%;
  border-radius: 0 0 24rpx 24rpx;
  background: linear-gradient(
    180deg,
    rgba(var(--accent-rgb), 0.15) 0%,
    rgba(var(--accent-rgb), 0.55) 45%,
    rgba(var(--accent-rgb), 0.35) 100%
  );
  animation: bottle-liquid 5s ease-in-out infinite;
}

@keyframes bottle-liquid {
  0%,
  100% {
    transform: translateY(0);
    opacity: 0.95;
  }
  50% {
    transform: translateY(-6rpx);
    opacity: 1;
  }
}

.bottle__label {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 140rpx;
  padding: 16rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(8, 8, 12, 0.55);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  text-align: center;
}

.bottle__label-small {
  display: block;
  font-size: 16rpx;
  letter-spacing: 0.2em;
  color: rgba(255, 255, 255, 0.35);
  margin-bottom: 8rpx;
}

.bottle__label-name {
  display: block;
  font-family: 'Songti SC', 'STSong', serif;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.3;
  max-height: 72rpx;
  overflow: hidden;
}

.bottle__shine {
  position: absolute;
  left: 50%;
  top: 60rpx;
  width: 40rpx;
  height: 360rpx;
  margin-left: -80rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.35) 50%,
    transparent 100%
  );
  opacity: 0.5;
  transform: rotate(8deg);
  pointer-events: none;
  animation: bottle-shine 6s ease-in-out infinite;
}

@keyframes bottle-shine {
  0%,
  100% {
    opacity: 0.35;
  }
  50% {
    opacity: 0.65;
  }
}

.bottle__base {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 120rpx;
  height: 24rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.35) 0%, transparent 70%);
}

/* —— Cocktail glass —— */
.glass {
  position: relative;
  width: 260rpx;
  height: 400rpx;
  filter: drop-shadow(0 20rpx 40rpx rgba(0, 0, 0, 0.4));
}

.glass__stem {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 16rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.15), rgba(255, 255, 255, 0.35));
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.glass__bowl {
  position: absolute;
  left: 50%;
  top: 0;
  transform: translateX(-50%);
  width: 220rpx;
  height: 260rpx;
  border-radius: 8rpx 8rpx 48rpx 48rpx;
  background: linear-gradient(
    120deg,
    rgba(255, 255, 255, 0.12) 0%,
    rgba(255, 255, 255, 0.28) 40%,
    rgba(255, 255, 255, 0.08) 100%
  );
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
  box-shadow: inset 0 -20rpx 40rpx rgba(0, 0, 0, 0.15);
}

.glass__liquid {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 72%;
  background: linear-gradient(
    180deg,
    rgba(var(--accent-rgb), 0.25) 0%,
    rgba(var(--accent-rgb), 0.65) 55%,
    rgba(var(--accent-rgb), 0.4) 100%
  );
  border-radius: 0 0 40rpx 40rpx;
}

.glass__wave {
  position: absolute;
  left: -20%;
  width: 140%;
  height: 40rpx;
  background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.25) 0%, transparent 70%);
  border-radius: 50%;
  animation: wave-move 3.2s ease-in-out infinite;
}

.glass__wave--1 {
  top: 18%;
  animation-delay: 0s;
}

.glass__wave--2 {
  top: 38%;
  opacity: 0.6;
  animation-delay: 0.8s;
  animation-duration: 2.6s;
}

@keyframes wave-move {
  0%,
  100% {
    transform: translateX(0) scaleX(1);
  }
  50% {
    transform: translateX(12rpx) scaleX(1.05);
  }
}

.glass__rim {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 12rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.45), rgba(255, 255, 255, 0.05));
}

.glass__spark {
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.75);
  box-shadow: 0 0 16rpx rgba(255, 255, 255, 0.8);
  animation: spark 2.4s ease-in-out infinite;
}

.glass__spark--a {
  top: 28%;
  left: 22%;
}

.glass__spark--b {
  top: 44%;
  right: 20%;
  animation-delay: 0.5s;
}

.glass__spark--c {
  top: 58%;
  left: 40%;
  animation-delay: 1s;
}

@keyframes spark {
  0%,
  100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  50% {
    opacity: 1;
    transform: scale(1.1);
  }
}

/* —— Fluid blobs —— */
.fluid {
  position: relative;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at 50% 40%, rgba(var(--accent-rgb), 0.12) 0%, transparent 55%);
}

.fluid__glow {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 360rpx;
  height: 360rpx;
  margin-left: -180rpx;
  margin-top: -180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(var(--accent-rgb), 0.35) 0%, transparent 65%);
  filter: blur(8rpx);
  animation: fluid-glow 8s ease-in-out infinite;
}

@keyframes fluid-glow {
  0%,
  100% {
    opacity: 0.6;
    transform: scale(1);
  }
  50% {
    opacity: 0.9;
    transform: scale(1.08);
  }
}

.fluid__blob {
  position: absolute;
  border-radius: 42% 58% 62% 38% / 48% 42% 58% 52%;
  filter: blur(0.5rpx);
  opacity: 0.85;
  mix-blend-mode: screen;
}

.fluid__blob--1 {
  width: 280rpx;
  height: 300rpx;
  left: 12%;
  top: 18%;
  background: linear-gradient(
    135deg,
    rgba(var(--accent-rgb), 0.85) 0%,
    rgba(var(--accent-rgb), 0.25) 100%
  );
  animation: blob-a 12s ease-in-out infinite;
}

.fluid__blob--2 {
  width: 240rpx;
  height: 260rpx;
  right: 10%;
  bottom: 16%;
  background: linear-gradient(
    220deg,
    rgba(255, 255, 255, 0.15) 0%,
    rgba(var(--accent-rgb), 0.55) 50%,
    rgba(var(--accent-rgb), 0.2) 100%
  );
  animation: blob-b 14s ease-in-out infinite;
}

.fluid__blob--3 {
  width: 200rpx;
  height: 220rpx;
  left: 32%;
  bottom: 22%;
  background: linear-gradient(
    45deg,
    rgba(var(--accent-rgb), 0.4) 0%,
    rgba(255, 255, 255, 0.12) 100%
  );
  animation: blob-c 10s ease-in-out infinite;
}

@keyframes blob-a {
  0%,
  100% {
    transform: translate(0, 0) rotate(0deg) scale(1);
    border-radius: 42% 58% 62% 38% / 48% 42% 58% 52%;
  }
  33% {
    transform: translate(16rpx, -20rpx) rotate(8deg) scale(1.05);
    border-radius: 58% 42% 38% 62% / 52% 48% 42% 58%;
  }
  66% {
    transform: translate(-12rpx, 12rpx) rotate(-6deg) scale(0.96);
    border-radius: 48% 52% 58% 42% / 44% 56% 48% 52%;
  }
}

@keyframes blob-b {
  0%,
  100% {
    transform: translate(0, 0) rotate(0deg);
    border-radius: 52% 48% 44% 56% / 46% 54% 50% 50%;
  }
  50% {
    transform: translate(-24rpx, -16rpx) rotate(-10deg);
    border-radius: 40% 60% 55% 45% / 55% 45% 55% 45%;
  }
}

@keyframes blob-c {
  0%,
  100% {
    transform: scale(1) translateY(0);
    opacity: 0.7;
  }
  50% {
    transform: scale(1.12) translateY(-10rpx);
    opacity: 1;
  }
}

.fluid__ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 320rpx;
  height: 320rpx;
  margin-left: -160rpx;
  margin-top: -160rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(var(--accent-rgb), 0.2);
  animation: ring-pulse 6s ease-in-out infinite;
}

@keyframes ring-pulse {
  0%,
  100% {
    transform: scale(0.92);
    opacity: 0.3;
  }
  50% {
    transform: scale(1);
    opacity: 0.55;
  }
}

/* Recipe */
.recipe-wrap {
  margin-top: 8rpx;
  padding: 8rpx 0 32rpx;
}

/* Bottom actions */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  display: flex;
  flex-direction: row;
  align-items: stretch;
  gap: 16rpx;
  padding: 20rpx 24rpx 24rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(8, 8, 12, 0.88) 28%, rgba(8, 8, 12, 0.96) 100%);
  backdrop-filter: blur(24rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.action {
  flex: 1;
  margin: 0;
  padding: 0 8rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
  border: none;
  font-weight: 500;
  letter-spacing: 0.04em;
}

.action::after {
  border: none;
}

.action--primary {
  color: #0a0a0f;
  background: linear-gradient(135deg, var(--accent) 0%, rgba(var(--accent-rgb), 0.85) 100%);
  box-shadow: 0 8rpx 32rpx rgba(var(--accent-rgb), 0.35);
}

.action--secondary {
  color: rgba(255, 255, 255, 0.88);
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.action--share {
  color: rgba(255, 255, 255, 0.9);
  background: rgba(var(--accent-rgb), 0.12);
  border: 1rpx solid rgba(var(--accent-rgb), 0.35);
}
