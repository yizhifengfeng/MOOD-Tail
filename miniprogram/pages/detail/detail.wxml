<view class="page" style="--accent: {{accentColor}}; --accent-rgb: {{accentRgb}};">
  <view class="nav" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="nav__inner">
      <view class="nav__btn" bindtap="onBack" aria-role="button" aria-label="返回">
        <text class="nav__icon">←</text>
      </view>
      <text class="nav__title">特调详情</text>
      <view class="nav__btn nav__btn--placeholder"></view>
    </view>
  </view>

  <scroll-view
    class="scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    style="padding-top: {{navBarHeight}}px;"
  >
    <view class="scroll__pad">
      <view class="hero {{titleVisible ? 'hero--visible' : ''}}">
        <text class="hero__title">{{cocktailName}}</text>
        <text class="hero__en" wx:if="{{cocktailNameEn}}">{{cocktailNameEn}}</text>
      </view>

      <!-- Direction-based illustration -->
      <view class="viz">
        <view class="viz__illu viz__illu--{{direction}}">
          <view wx:if="{{direction === 'bright'}}" class="illu-bottle illu-bottle--bright">
            <view class="illu-bottle__cap"></view>
            <view class="illu-bottle__neck"></view>
            <view class="illu-bottle__body">
              <view class="illu-bottle__liquid illu-bottle__liquid--bright"></view>
              <view class="illu-bottle__shine"></view>
            </view>
            <view class="illu-bottle__base"></view>
          </view>

          <view wx:elif="{{direction === 'calm'}}" class="illu-glass">
            <view class="illu-glass__stem"></view>
            <view class="illu-glass__bowl">
              <view class="illu-glass__liquid">
                <view class="illu-glass__wave illu-glass__wave--1"></view>
                <view class="illu-glass__wave illu-glass__wave--2"></view>
              </view>
              <view class="illu-glass__rim"></view>
            </view>
          </view>

          <view wx:else class="illu-bottle illu-bottle--deep">
            <view class="illu-bottle__cap illu-bottle__cap--deep"></view>
            <view class="illu-bottle__neck illu-bottle__neck--wide"></view>
            <view class="illu-bottle__body illu-bottle__body--squat">
              <view class="illu-bottle__liquid illu-bottle__liquid--deep"></view>
              <view class="illu-bottle__shine illu-bottle__shine--dim"></view>
            </view>
            <view class="illu-bottle__base illu-bottle__base--wide"></view>
          </view>
        </view>
      </view>

      <!-- Emotion summary -->
      <view class="info glass-block" wx:if="{{emotionData || emotionText}}">
        <view class="info__row">
          <text class="info__label">情绪方向</text>
          <view class="pill pill--{{direction}}">
            <text class="pill__text">{{directionLabel}}</text>
          </view>
        </view>
        <view class="info__row" wx:if="{{emotionData}}">
          <text class="info__label">强度</text>
          <text class="info__value">{{intensityText}}</text>
        </view>
        <view class="info__row" wx:if="{{emotionData}}">
          <text class="info__label">滑杆</text>
          <text class="info__value">{{sliderText}}</text>
        </view>
        <view class="info__row info__row--block" wx:if="{{emotionText}}">
          <text class="info__label">原文</text>
          <text class="info__quote-inline">{{emotionText}}</text>
        </view>
      </view>

      <view class="recipe-wrap">
        <recipe-card recipe="{{recipe}}" direction="{{direction}}" />
      </view>

      <view class="quote-block glass-block" wx:if="{{emotionText}}">
        <text class="quote-block__lead">你当时说：</text>
        <text class="quote-block__body">「{{emotionText}}」</text>
      </view>

      <view class="meta" wx:if="{{savedAtText}}">
        <text class="meta__label">保存于</text>
        <text class="meta__time">{{savedAtText}}</text>
      </view>

      <view class="scroll__bottom-spacer"></view>
    </view>
  </scroll-view>

  <view class="action-bar" style="padding-bottom: calc(24rpx + {{safeAreaBottom}}px);">
    <button class="action action--primary" bindtap="onMixAnother">再调一杯</button>
    <button class="action action--share" open-type="share">分享</button>
  </view>
</view>
