.page {
  min-height: 100vh;
  background: var(--color-bg, #0a0a0f);
  box-sizing: border-box;
}

/* —— Nav —— */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(
    180deg,
    rgba(10, 10, 15, 0.96) 0%,
    rgba(10, 10, 15, 0.88) 70%,
    transparent 100%
  );
}

.nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx 0 8rpx;
  height: 100%;
  box-sizing: border-box;
}

.nav__btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.nav__btn--placeholder {
  visibility: hidden;
  pointer-events: none;
}

.nav__icon {
  font-size: 40rpx;
  color: var(--color-text-primary, #eaeaea);
  line-height: 1;
}

.nav__title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  color: var(--color-text-primary, #eaeaea);
}

/* —— Scroll —— */
.scroll {
  height: 100vh;
  box-sizing: border-box;
}

.scroll__pad {
  padding: 0 40rpx 280rpx;
}

.scroll__bottom-spacer {
  height: 32rpx;
}

/* —— Hero —— */
.hero {
  padding-top: 16rpx;
  opacity: 0;
  transform: translateY(16rpx);
  transition: opacity 0.5s ease, transform 0.5s ease;
}

.hero--visible {
  opacity: 1;
  transform: translateY(0);
}

.hero__title {
  display: block;
  font-family: var(--font-serif, Georgia, 'Noto Serif SC', serif);
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1.2;
  color: var(--color-text-primary, #eaeaea);
  letter-spacing: 2rpx;
}

.hero__en {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary, #8b8b9e);
  letter-spacing: 3rpx;
  text-transform: none;
}

/* —— Illustration —— */
.viz {
  margin-top: 40rpx;
  margin-bottom: 32rpx;
}

.viz__illu {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 280rpx;
}

/* Bright: tall bottle */
.illu-bottle {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.illu-bottle__cap {
  width: 48rpx;
  height: 20rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: linear-gradient(90deg, #4a4a5a, #6a6a7a);
}

.illu-bottle__cap--deep {
  width: 64rpx;
  background: linear-gradient(90deg, #2a2a38, #3d3d4d);
}

.illu-bottle__neck {
  width: 36rpx;
  height: 32rpx;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.15),
    rgba(255, 255, 255, 0.04)
  );
  border-left: 2rpx solid rgba(255, 255, 255, 0.12);
  border-right: 2rpx solid rgba(255, 255, 255, 0.06);
}

.illu-bottle__neck--wide {
  width: 52rpx;
  height: 28rpx;
}

.illu-bottle__body {
  position: relative;
  width: 140rpx;
  height: 200rpx;
  border-radius: 24rpx 24rpx 32rpx 32rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.12);
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.08),
    rgba(255, 255, 255, 0.02)
  );
}

.illu-bottle__body--squat {
  width: 168rpx;
  height: 160rpx;
  border-radius: 28rpx;
}

.illu-bottle__liquid {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 78%;
  border-radius: 0 0 20rpx 20rpx;
}

.illu-bottle__liquid--bright {
  background: linear-gradient(
    180deg,
    #ffd93d 0%,
    var(--color-bright-primary, #ff9f43) 45%,
    #ff6b35 100%
  );
  box-shadow: inset 0 -20rpx 40rpx rgba(255, 200, 100, 0.35);
}

.illu-bottle__liquid--deep {
  height: 85%;
  background: linear-gradient(
    180deg,
    #4c1d95 0%,
    var(--color-deep-primary, #a855f7) 40%,
    #1e1030 100%
  );
  box-shadow: inset 0 -16rpx 32rpx rgba(0, 0, 0, 0.45);
}

.illu-bottle__shine {
  position: absolute;
  top: 16%;
  left: 12%;
  width: 24rpx;
  height: 55%;
  border-radius: 40rpx;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.35),
    rgba(255, 255, 255, 0)
  );
}

.illu-bottle__shine--dim {
  opacity: 0.25;
}

.illu-bottle__base {
  margin-top: -2rpx;
  width: 100rpx;
  height: 16rpx;
  border-radius: 0 0 12rpx 12rpx;
  background: linear-gradient(90deg, #3a3a48, #5a5a68);
}

.illu-bottle__base--wide {
  width: 120rpx;
}

/* Calm: cocktail glass */
.illu-glass {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.illu-glass__stem {
  width: 16rpx;
  height: 56rpx;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.2),
    rgba(255, 255, 255, 0.06)
  );
  border-radius: 8rpx;
}

.illu-glass__bowl {
  position: relative;
  width: 160rpx;
  height: 180rpx;
  border-radius: 8rpx 8rpx 64rpx 64rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  background: linear-gradient(
    160deg,
    rgba(255, 255, 255, 0.12),
    rgba(78, 205, 196, 0.08)
  );
}

.illu-glass__liquid {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 10rpx;
  top: 28rpx;
  border-radius: 4rpx 4rpx 48rpx 48rpx;
  background: linear-gradient(
    180deg,
    rgba(72, 219, 251, 0.5) 0%,
    var(--color-calm-primary, #4ecdc4) 55%,
    rgba(15, 52, 96, 0.85) 100%
  );
  overflow: hidden;
}

.illu-glass__wave {
  position: absolute;
  left: -20%;
  width: 140%;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.illu-glass__wave--1 {
  bottom: 35%;
  animation: waveMove 4s ease-in-out infinite;
}

.illu-glass__wave--2 {
  bottom: 52%;
  opacity: 0.6;
  animation: waveMove 5s ease-in-out infinite reverse;
}

@keyframes waveMove {
  0%,
  100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(12rpx);
  }
}

.illu-glass__rim {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 12rpx;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.25),
    transparent
  );
}

/* —— Info & quote —— */
.glass-block {
  background: rgba(26, 26, 46, 0.55);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-lg, 24rpx);
  padding: 28rpx 32rpx;
  margin-bottom: 28rpx;
}

.info__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.info__row:last-child {
  margin-bottom: 0;
}

.info__row--block {
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
}

.info__label {
  font-size: 24rpx;
  color: var(--color-text-secondary, #8b8b9e);
}

.info__value {
  font-size: 28rpx;
  color: var(--color-text-primary, #eaeaea);
  font-weight: 500;
}

.info__quote-inline {
  font-size: 26rpx;
  color: var(--color-text-primary, #eaeaea);
  line-height: 1.5;
}

.pill {
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full, 999rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.pill--bright {
  background: rgba(255, 159, 67, 0.18);
  border-color: rgba(255, 159, 67, 0.35);
}

.pill--calm {
  background: rgba(78, 205, 196, 0.18);
  border-color: rgba(78, 205, 196, 0.35);
}

.pill--deep {
  background: rgba(168, 85, 247, 0.18);
  border-color: rgba(168, 85, 247, 0.35);
}

.pill__text {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-primary, #eaeaea);
}

.quote-block {
  border-left: 6rpx solid var(--accent, #4ecdc4);
  padding-left: 28rpx;
}

.quote-block__lead {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-secondary, #8b8b9e);
  margin-bottom: 12rpx;
}

.quote-block__body {
  display: block;
  font-family: var(--font-serif, Georgia, 'Noto Serif SC', serif);
  font-size: 30rpx;
  font-style: italic;
  line-height: 1.65;
  color: var(--color-text-primary, #eaeaea);
}

.meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 8rpx 4rpx 32rpx;
}

.meta__label {
  font-size: 22rpx;
  color: var(--color-text-hint, #5a5a6e);
  letter-spacing: 1rpx;
}

.meta__time {
  font-size: 26rpx;
  color: var(--color-text-secondary, #8b8b9e);
}

.recipe-wrap {
  margin-bottom: 8rpx;
}

/* —— Bottom actions —— */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: 24rpx;
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(10, 10, 15, 0.92) 28%,
    #0a0a0f 100%
  );
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  box-sizing: border-box;
}

.action {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: var(--radius-full, 999rpx);
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  border: none;
  margin: 0;
  padding: 0;
}

.action::after {
  border: none;
}

.action--primary {
  background: linear-gradient(
    135deg,
    var(--color-deep-primary, #a855f7),
    var(--color-deep-secondary, #6c5ce7)
  );
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(168, 85, 247, 0.28);
}

.action--share {
  background: rgba(255, 255, 255, 0.08);
  color: var(--color-text-primary, #eaeaea);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}
