<view class="page">
  <view class="nav" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
    <view class="nav__inner">
      <view class="nav__btn" bindtap="onBack" aria-role="button" aria-label="返回">
        <text class="nav__icon">←</text>
      </view>
      <text class="nav__title">酒吧产品</text>
      <view class="nav__btn nav__btn--placeholder"></view>
    </view>
  </view>

  <view class="body" style="padding-top: {{bodyPadTop}}px;">
    <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="filter-row">
        <view
          wx:for="{{filterTabs}}"
          wx:key="key"
          class="filter-pill filter-pill--{{item.key}} {{filter === item.key ? 'filter-pill--active' : ''}}"
          data-key="{{item.key}}"
          bindtap="onFilterTap"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="empty" wx:if="{{filteredProducts.length === 0}}">
      <text class="empty__icon">🥃</text>
      <text class="empty__title">暂无该方向的产品</text>
      <text class="empty__hint">试试切换上方筛选</text>
    </view>

    <view class="grid" wx:else>
      <view
        wx:for="{{filteredProducts}}"
        wx:key="id"
        class="card-wrap"
      >
        <view
          class="card card--{{item.direction}} {{expandedId === item.id ? 'card--open' : ''}}"
          data-id="{{item.id}}"
          bindtap="onToggleCard"
        >
          <view class="card__accent"></view>
          <image wx:if="{{item.image}}" class="card__img" src="{{item.image}}" mode="aspectFill" lazy-load />
          <view class="card__main">
            <text class="card__name">{{item.name}}</text>
            <text class="card__name-en" wx:if="{{item.nameEn}}">{{item.nameEn}}</text>
            <text class="card__category">{{item.category}}</text>
            <view class="card__tags">
              <text
                wx:for="{{item.emotion_tags}}"
                wx:for-item="tag"
                wx:key="*this"
                class="card__tag"
              >{{tag}}</text>
            </view>
            <text class="card__desc">{{item.description}}</text>

            <view class="card__detail" wx:if="{{expandedId === item.id}}">
              <view class="card__detail-sep"></view>
              <text class="card__detail-label">原料</text>
              <text class="card__ingredients">{{item.ingredients.join(' · ')}}</text>
            </view>

            <text class="card__hint">{{expandedId === item.id ? '点击收起' : '点击查看详情'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="safe-pad" style="padding-bottom: calc(32rpx + {{safeAreaBottom}}px);"></view>
  </view>
</view>
