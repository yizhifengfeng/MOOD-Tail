/* ========== MOOD Tail Global Styles ========== */

page {
  --color-bg: #0A0A0F;
  --color-surface: #1A1A2E;
  --color-card: #16213E;
  --color-card-light: #1E2A45;
  --color-border: rgba(255, 255, 255, 0.06);
  --color-text-primary: #EAEAEA;
  --color-text-secondary: #8B8B9E;
  --color-text-hint: #5A5A6E;
  --color-bright-primary: #FF9F43;
  --color-bright-secondary: #FECA57;
  --color-calm-primary: #4ECDC4;
  --color-calm-secondary: #48DBFB;
  --color-deep-primary: #A855F7;
  --color-deep-secondary: #6C5CE7;
  --color-accent: #A855F7;
  --color-danger: #FF6B6B;
  --color-success: #2ED573;
  --font-serif: Georgia, 'Noto Serif SC', serif;
  --font-sans: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 36rpx;
  --radius-full: 999rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  --shadow-md: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  --shadow-lg: 0 16rpx 48rpx rgba(0, 0, 0, 0.5);
  --shadow-glow: 0 0 30rpx rgba(168, 85, 247, 0.3);

  background-color: var(--color-bg);
  color: var(--color-text-primary);
  font-family: var(--font-sans);
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* Scrollbar hidden */
::-webkit-scrollbar {
  display: none;
}

/* Glass effect */
.glass {
  background: rgba(26, 26, 46, 0.6);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.glass-light {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

/* Text utilities */
.text-bright { color: var(--color-bright-primary); }
.text-calm { color: var(--color-calm-primary); }
.text-deep { color: var(--color-deep-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-hint { color: var(--color-text-hint); }
.text-center { text-align: center; }
.text-serif { font-family: var(--font-serif); }

/* Flex utilities */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }

/* Spacing */
.container {
  padding: 0 40rpx;
}

/* Fade animations */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes breathe {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.05); opacity: 1; }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes shimmer {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}

.animate-fadeIn {
  animation: fadeIn 0.6s ease-out forwards;
}

.animate-fadeInUp {
  animation: fadeInUp 0.8s ease-out forwards;
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

.animate-breathe {
  animation: breathe 4s ease-in-out infinite;
}

.animate-float {
  animation: float 3s ease-in-out infinite;
}

/* Button base */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  transition: all 0.3s ease;
  border: none;
  outline: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, var(--color-deep-primary), var(--color-deep-secondary));
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(168, 85, 247, 0.3);
}

.btn-primary:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(168, 85, 247, 0.2);
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: var(--color-text-primary);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.btn-secondary:active {
  background: rgba(255, 255, 255, 0.12);
}

.btn-disabled {
  opacity: 0.4;
  pointer-events: none;
}

/* Safe area */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-top {
  padding-top: env(safe-area-inset-top);
}
