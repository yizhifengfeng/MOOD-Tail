<view class="recipe-card {{compact ? 'recipe-card--compact' : ''}}" style="--accent: {{accentColor}}; --accent-glow: {{accentGlow}};">
  <view class="recipe-card__border"></view>
  <view class="recipe-card__body">
    <view class="recipe-card__inner-dots" aria-hidden="true"></view>
    <view class="recipe-card__header">
      <text class="recipe-card__title">你的情绪配方</text>
      <view class="recipe-card__deco">
        <view class="recipe-card__deco-line"></view>
        <view class="recipe-card__deco-dot"></view>
        <view class="recipe-card__deco-line"></view>
      </view>
    </view>

    <view class="recipe-card__sep"></view>

    <view class="recipe-card__lead" wx:if="{{summary}}">
      <text class="recipe-card__summary recipe-card__summary--italic">{{summary}}</text>
    </view>
    <view class="recipe-card__sep" wx:if="{{summary}}"></view>

    <view class="recipe-card__row">
      <text class="recipe-card__label">基酒</text>
      <view class="recipe-card__main">
        <text class="recipe-card__serif recipe-card__strong">{{baseNameCn}}</text>
        <text class="recipe-card__base-en" wx:if="{{baseNameEn}}">{{baseNameEn}}</text>
        <text class="recipe-card__text">{{baseFlavor}}</text>
      </view>
    </view>

    <view class="recipe-card__sep recipe-card__sep--dotted"></view>

    <view class="recipe-card__notes-section">
      <view class="recipe-card__notes-grid">
        <view class="recipe-card__note-col">
          <view class="recipe-card__note-badge">前调</view>
          <text class="recipe-card__serif recipe-card__note-name">{{topIngredient}}</text>
          <text class="recipe-card__note-desc">{{topMood}}</text>
        </view>
        <view class="recipe-card__note-col recipe-card__note-col--mid">
          <view class="recipe-card__note-badge">中调</view>
          <text class="recipe-card__serif recipe-card__note-name">{{midIngredient}}</text>
          <text class="recipe-card__note-desc">{{midMood}}</text>
        </view>
        <view class="recipe-card__note-col">
          <view class="recipe-card__note-badge">尾调</view>
          <text class="recipe-card__serif recipe-card__note-name">{{tailIngredient}}</text>
          <text class="recipe-card__note-desc">{{tailMood}}</text>
        </view>
      </view>
    </view>

    <view class="recipe-card__sep" wx:if="{{!hideBottomMeter}}"></view>

    <view class="recipe-card__bottom-row" wx:if="{{!hideBottomMeter}}">
      <view class="recipe-card__info-item">
        <text class="recipe-card__label">体感</text>
        <text class="recipe-card__text recipe-card__accent">{{feeling}}</text>
      </view>
      <view class="recipe-card__info-item recipe-card__info-item--conc">
        <view class="recipe-card__row-head">
          <text class="recipe-card__label">浓度</text>
          <text class="recipe-card__text recipe-card__percent">{{concentrationText}}</text>
        </view>
        <view class="recipe-card__bar-track">
          <view class="recipe-card__bar-fill" style="width: {{progressPercent}}%;"></view>
        </view>
      </view>
    </view>

  </view>
</view>
