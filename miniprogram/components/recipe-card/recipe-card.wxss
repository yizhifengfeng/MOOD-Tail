/* 情绪配方卡 — receipt / ticket */

.recipe-card {
  position: relative;
  border-radius: 24rpx;
  padding: 40rpx;
  box-sizing: border-box;
  background: rgba(22, 33, 62, 0.8);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow:
    0 8rpx 32rpx rgba(0, 0, 0, 0.45),
    0 0 0 1rpx rgba(255, 255, 255, 0.04) inset,
    0 0 36rpx var(--accent-glow);
}

.recipe-card__border {
  pointer-events: none;
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 12rpx;
  bottom: 12rpx;
  border-radius: 18rpx;
  border: 1rpx dashed rgba(255, 255, 255, 0.12);
}

.recipe-card__body {
  position: relative;
  z-index: 1;
}

.recipe-card__header {
  align-items: center;
  text-align: center;
  margin-bottom: 8rpx;
}

.recipe-card__title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 0.12em;
  color: #eaeaea;
}

.recipe-card__deco {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  gap: 12rpx;
}

.recipe-card__deco-line {
  flex: 1;
  max-width: 120rpx;
  height: 1rpx;
  background: linear-gradient(
    90deg,
    transparent,
    var(--accent),
    transparent
  );
  opacity: 0.85;
}

.recipe-card__deco-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 14rpx var(--accent-glow);
}

.recipe-card__sep {
  margin: 28rpx 0;
  height: 0;
  border-top: 1rpx dashed rgba(255, 255, 255, 0.18);
}

.recipe-card__sep--tight {
  margin: 18rpx 0;
}

.recipe-card__row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.recipe-card__row--single {
  align-items: center;
}

.recipe-card__row--conc {
  flex-direction: column;
  align-items: stretch;
  gap: 16rpx;
}

.recipe-card__row-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.recipe-card__label {
  flex-shrink: 0;
  width: 112rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #8b8b9e;
}

.recipe-card__main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  text-align: right;
  gap: 8rpx;
}

.recipe-card__serif {
  font-family: Georgia, 'Noto Serif SC', 'Songti SC', serif;
}

.recipe-card__strong {
  font-size: 30rpx;
  font-weight: 600;
  color: #eaeaea;
}

.recipe-card__text {
  font-size: 26rpx;
  line-height: 1.55;
  color: #eaeaea;
}

.recipe-card__muted-sm {
  font-size: 24rpx;
  color: #a5a5b8;
}

.recipe-card__accent {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--accent);
}

.recipe-card__percent {
  font-size: 28rpx;
  font-weight: 600;
  color: #eaeaea;
  font-variant-numeric: tabular-nums;
}

.recipe-card__bar-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.recipe-card__bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.22), var(--accent));
  box-shadow: 0 0 12rpx var(--accent-glow);
  transition: width 0.35s ease;
}

.recipe-card__footer {
  padding-top: 8rpx;
  text-align: center;
}

.recipe-card__summary {
  font-size: 24rpx;
  line-height: 1.65;
  color: #a5a5b8;
}
