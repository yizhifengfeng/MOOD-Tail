<view class="cocktail-root">
  <view class="glass-stage">
    <view class="glass-outer">
      <view class="glass-rim"></view>
      <view class="glass-body {{isAnalyzing ? 'glass-body--active' : ''}}">
        <view class="glass-highlight glass-highlight--left"></view>
        <view class="glass-highlight glass-highlight--right"></view>
        <view class="glass-inner-edge"></view>

        <view
          class="liquid-column"
          style="--liquid: {{liquidColor}}; --liquid-light: {{liquidLight}}; --liquid-dark: {{liquidDark}}; --wave-duration: {{waveDuration}}s; --wave-duration-b: {{waveDurationB}}s; --wave-duration-c: {{waveDurationC}}s; --wave-amplitude: {{waveAmplitude}}rpx;"
        >
          <view class="liquid-fill">
            <view class="liquid-core"></view>
            <view class="liquid-shimmer"></view>
          </view>
          <view class="liquid-surface">
            <view class="wave wave-a"></view>
            <view class="wave wave-b"></view>
            <view class="wave wave-c"></view>
          </view>
          <view class="liquid-meniscus"></view>
        </view>

        <canvas type="2d" id="bubbleCanvas" class="bubble-canvas"></canvas>

        <view class="glow-orb" style="opacity: {{glowOpacity}}; background: {{glowGradient}};"></view>
        <view
          class="smoke smoke-1"
          style="opacity: {{smokeOpacity}}; animation-duration: {{smokeDuration}}s;"
        ></view>
        <view
          class="smoke smoke-2"
          style="opacity: {{smokeOpacity}}; animation-duration: {{smokeDuration2}}s;"
        ></view>
        <view class="vignette"></view>
      </view>
      <view class="glass-base"></view>
      <view class="glass-foot"></view>
    </view>
  </view>
  <text class="status-text">{{statusText}}</text>
</view>
