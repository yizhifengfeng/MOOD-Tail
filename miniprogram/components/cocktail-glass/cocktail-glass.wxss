/* Root — dark stage */
.cocktail-root {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 560rpx;
  padding: 32rpx 24rpx 24rpx;
  box-sizing: border-box;
  background: #0a0a0f;
}

.glass-stage {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  width: 100%;
}

/* Tall mixing-glass silhouette */
.glass-outer {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 400rpx;
}

.glass-rim {
  width: 340rpx;
  height: 14rpx;
  border-radius: 50%;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.12) 0%,
    rgba(255, 255, 255, 0.42) 42%,
    rgba(255, 255, 255, 0.55) 50%,
    rgba(255, 255, 255, 0.38) 58%,
    rgba(255, 255, 255, 0.1) 100%
  );
  box-shadow:
    0 4rpx 16rpx rgba(0, 0, 0, 0.45),
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.35);
  z-index: 4;
}

.glass-body {
  position: relative;
  width: 400rpx;
  height: 500rpx;
  margin-top: -6rpx;
  border-radius: 28rpx 28rpx 36rpx 36rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  border-top-color: rgba(255, 255, 255, 0.35);
  background: linear-gradient(
    105deg,
    rgba(255, 255, 255, 0.06) 0%,
    rgba(255, 255, 255, 0.14) 45%,
    rgba(255, 255, 255, 0.08) 52%,
    rgba(255, 255, 255, 0.04) 100%
  );
  box-shadow:
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.12),
    inset -20rpx 0 40rpx rgba(255, 255, 255, 0.06),
    inset 24rpx 0 50rpx rgba(0, 0, 0, 0.18),
    0 24rpx 48rpx rgba(0, 0, 0, 0.55),
    0 0 80rpx rgba(120, 160, 255, 0.06);
  overflow: hidden;
  transform: perspective(900rpx) rotateX(2deg);
}

.glass-body--active {
  box-shadow:
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.15),
    inset -20rpx 0 40rpx rgba(255, 255, 255, 0.08),
    inset 24rpx 0 50rpx rgba(0, 0, 0, 0.2),
    0 28rpx 56rpx rgba(0, 0, 0, 0.6),
    0 0 100rpx rgba(120, 200, 255, 0.12);
}

.glass-highlight {
  position: absolute;
  top: 12%;
  width: 18%;
  height: 68%;
  border-radius: 40rpx;
  pointer-events: none;
  z-index: 3;
}

.glass-highlight--left {
  left: 8%;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.35) 0%,
    rgba(255, 255, 255, 0.08) 45%,
    transparent 100%
  );
  filter: blur(2rpx);
  opacity: 0.65;
}

.glass-highlight--right {
  right: 10%;
  width: 12%;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.12) 0%,
    transparent 70%
  );
  opacity: 0.4;
}

.glass-inner-edge {
  position: absolute;
  inset: 10rpx;
  border-radius: 22rpx 22rpx 30rpx 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  pointer-events: none;
  z-index: 2;
}

/* Liquid column */
.liquid-column {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 78%;
  height: 72%;
  z-index: 1;
  overflow: hidden;
  border-radius: 0 0 20rpx 20rpx;
}

.liquid-fill {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  overflow: hidden;
}

.liquid-core {
  position: absolute;
  left: -8%;
  right: -8%;
  bottom: 0;
  height: 102%;
  background: linear-gradient(
    180deg,
    var(--liquid-light) 0%,
    var(--liquid) 42%,
    var(--liquid-dark) 100%
  );
  opacity: 0.96;
}

/* Fallback where color-mix unsupported — still readable */
.liquid-shimmer {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100%;
  background: linear-gradient(
    115deg,
    transparent 0%,
    rgba(255, 255, 255, 0.12) 42%,
    transparent 55%,
    rgba(0, 0, 0, 0.08) 100%
  );
  mix-blend-mode: overlay;
  animation: liquidShimmer 4.5s ease-in-out infinite;
}

@keyframes liquidShimmer {
  0%,
  100% {
    opacity: 0.45;
    transform: translateX(-4%);
  }
  50% {
    opacity: 0.75;
    transform: translateX(4%);
  }
}

/* Wave surface — layered sine-like motion */
.liquid-surface {
  position: absolute;
  left: -30%;
  right: -30%;
  top: 0;
  height: 56rpx;
  pointer-events: none;
  z-index: 2;
}

.wave {
  position: absolute;
  left: 0;
  width: 200%;
  height: 100%;
  top: 0;
  opacity: 0.85;
  will-change: transform;
}

.wave-a {
  background: radial-gradient(
    ellipse 120rpx 28rpx at 50% 100%,
    var(--liquid) 0%,
    transparent 72%
  );
  background-size: 140rpx 56rpx;
  background-repeat: repeat-x;
  background-position: 0 0;
  animation: waveDrift var(--wave-duration, 2.4s) linear infinite;
}

.wave-b {
  top: 6rpx;
  opacity: 0.55;
  background: radial-gradient(
    ellipse 100rpx 22rpx at 50% 100%,
    rgba(255, 255, 255, 0.35) 0%,
    transparent 70%
  );
  background-size: 110rpx 44rpx;
  background-repeat: repeat-x;
  animation: waveDrift var(--wave-duration-b, 3.2s) linear infinite reverse;
}

.wave-c {
  top: -4rpx;
  opacity: 0.4;
  background: radial-gradient(
    ellipse 90rpx 18rpx at 50% 100%,
    rgba(255, 255, 255, 0.28) 0%,
    transparent 68%
  );
  background-size: 95rpx 36rpx;
  background-repeat: repeat-x;
  animation: waveDrift var(--wave-duration-c, 1.7s) linear infinite;
}

@keyframes waveDrift {
  0% {
    transform: translateX(0) translateY(var(--wave-amplitude, 4rpx));
  }
  50% {
    transform: translateX(-25%) translateY(calc(var(--wave-amplitude, 4rpx) * -1));
  }
  100% {
    transform: translateX(-50%) translateY(var(--wave-amplitude, 4rpx));
  }
}

.liquid-meniscus {
  position: absolute;
  left: 4%;
  right: 4%;
  top: 0;
  height: 8rpx;
  border-radius: 50%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.35),
    transparent
  );
  opacity: 0.55;
  z-index: 3;
}

/* Canvas overlay — bubbles */
.bubble-canvas {
  position: absolute;
  left: 0;
  top: 0;
  width: 400rpx;
  height: 500rpx;
  z-index: 5;
  pointer-events: none;
}

/* Glow from intensity + emotion */
.glow-orb {
  position: absolute;
  left: 50%;
  bottom: 8%;
  width: 280rpx;
  height: 220rpx;
  margin-left: -140rpx;
  border-radius: 50%;
  filter: blur(28rpx);
  pointer-events: none;
  z-index: 4;
  animation: glowPulse 3.2s ease-in-out infinite;
}

@keyframes glowPulse {
  0%,
  100% {
    transform: scale(1);
    filter: blur(28rpx);
  }
  50% {
    transform: scale(1.06);
    filter: blur(32rpx);
  }
}

/* Smoke / mist */
.smoke {
  position: absolute;
  left: 50%;
  width: 320rpx;
  height: 180rpx;
  margin-left: -160rpx;
  bottom: 58%;
  border-radius: 50%;
  background: radial-gradient(
    ellipse at center,
    rgba(200, 220, 255, 0.2) 0%,
    rgba(160, 180, 220, 0.08) 35%,
    transparent 65%
  );
  filter: blur(24rpx);
  pointer-events: none;
  z-index: 6;
  animation: smokeRise 5s ease-in-out infinite;
}

.smoke-2 {
  width: 260rpx;
  margin-left: -130rpx;
  bottom: 52%;
  animation-name: smokeRise2;
}

@keyframes smokeRise {
  0% {
    transform: translateY(10rpx) translateX(-6rpx) scale(0.9);
    opacity: 0.3;
  }
  50% {
    transform: translateY(-24rpx) translateX(8rpx) scale(1.05);
    opacity: 0.55;
  }
  100% {
    transform: translateY(-50rpx) translateX(-4rpx) scale(1.1);
    opacity: 0.2;
  }
}

@keyframes smokeRise2 {
  0% {
    transform: translateY(6rpx) translateX(10rpx) scale(0.85);
    opacity: 0.25;
  }
  50% {
    transform: translateY(-30rpx) translateX(-10rpx) scale(1.08);
    opacity: 0.5;
  }
  100% {
    transform: translateY(-56rpx) translateX(6rpx) scale(1.12);
    opacity: 0.15;
  }
}

.vignette {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  box-shadow: inset 0 0 60rpx rgba(0, 0, 0, 0.35);
  pointer-events: none;
  z-index: 7;
}

/* Stem / base — mixing glass stand */
.glass-base {
  width: 120rpx;
  height: 28rpx;
  margin-top: -2rpx;
  background: linear-gradient(
    90deg,
    rgba(255, 255, 255, 0.08) 0%,
    rgba(255, 255, 255, 0.22) 50%,
    rgba(255, 255, 255, 0.08) 100%
  );
  border-radius: 0 0 12rpx 12rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.4);
  z-index: 2;
}

.glass-foot {
  width: 200rpx;
  height: 16rpx;
  margin-top: -2rpx;
  border-radius: 50%;
  background: radial-gradient(
    ellipse at center,
    rgba(255, 255, 255, 0.2) 0%,
    rgba(40, 40, 55, 0.9) 70%,
    rgba(10, 10, 15, 1) 100%
  );
  box-shadow: 0 12rpx 24rpx rgba(0, 0, 0, 0.55);
  z-index: 1;
}

.status-text {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 0.06em;
  font-weight: 300;
}
