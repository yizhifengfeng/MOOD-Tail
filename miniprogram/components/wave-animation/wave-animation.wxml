<!-- 分析态 · 柔化 Siri 波纹 + 呼吸核 + 微动气流 + 渐亮粒子 -->
<view class="sense sense--{{ dirClass }} {{ active ? 'sense--active' : '' }}">
  <view class="sense__vignette" />
  <view class="sense__ripples">
    <view class="sense__ring sense__ring--1" />
    <view class="sense__ring sense__ring--2" />
    <view class="sense__ring sense__ring--3" />
    <view class="sense__ring sense__ring--4" />
  </view>
  <view class="sense__core">
    <view class="sense__bloom sense__bloom--a" />
    <view class="sense__bloom sense__bloom--b" />
    <view class="sense__bloom sense__bloom--c" />
    <view class="sense__core-ring" />
  </view>
  <block wx:for="{{particles}}" wx:key="id">
    <view
      class="sense__particle"
      style="left: {{ item.x }}%; top: {{ item.y }}%; animation-delay: {{ item.d }}s; animation-duration: {{ item.dur }}s;"
    />
  </block>
  <view wx:if="{{ active && statusText }}" class="sense__caption">{{ statusText }}</view>
</view>
