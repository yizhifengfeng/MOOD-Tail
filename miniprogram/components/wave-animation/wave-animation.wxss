/* Siri-like wave + dark theme; direction palettes: bright / calm / deep */

.wave-animation {
  width: 500rpx;
  min-height: 500rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 24rpx;
  border-radius: 32rpx;
  background: radial-gradient(ellipse at 50% 38%, rgba(30, 32, 44, 0.95) 0%, #0d0e14 55%, #08090d 100%);
  --ring-color: rgba(78, 205, 196, 0.55);
  --ring-color-soft: rgba(78, 205, 196, 0.12);
  --glow-center: rgba(78, 205, 196, 0.45);
  --glow-outer: rgba(72, 219, 251, 0.08);
  --status-color: #7ed6df;
}

.wave-animation--bright {
  --ring-color: rgba(255, 159, 67, 0.6);
  --ring-color-soft: rgba(255, 202, 87, 0.14);
  --glow-center: rgba(255, 200, 120, 0.5);
  --glow-outer: rgba(255, 159, 67, 0.1);
  --status-color: #feca57;
}

.wave-animation--calm {
  --ring-color: rgba(78, 205, 196, 0.55);
  --ring-color-soft: rgba(78, 205, 196, 0.12);
  --glow-center: rgba(78, 205, 196, 0.45);
  --glow-outer: rgba(72, 219, 251, 0.08);
  --status-color: #7ed6df;
}

.wave-animation--deep {
  --ring-color: rgba(168, 85, 247, 0.55);
  --ring-color-soft: rgba(108, 92, 231, 0.14);
  --glow-center: rgba(168, 85, 247, 0.48);
  --glow-outer: rgba(108, 92, 231, 0.1);
  --status-color: #c4b5fd;
}

.wave-animation__stage {
  position: relative;
  width: 420rpx;
  height: 420rpx;
  flex-shrink: 0;
  animation: wave-breathe 4.2s ease-in-out infinite;
}

.wave-animation--active .wave-animation__stage {
  animation: wave-breathe 4.2s ease-in-out infinite;
}

.wave-animation:not(.wave-animation--active) .wave-animation__stage {
  animation: none;
  opacity: 0.65;
}

.wave-animation__rings {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 100%;
  height: 100%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.wave-animation__ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 80rpx;
  height: 80rpx;
  margin-left: -40rpx;
  margin-top: -40rpx;
  border-radius: 50%;
  border: 2rpx solid var(--ring-color);
  box-shadow: 0 0 24rpx var(--ring-color-soft);
  opacity: 0;
}

.wave-animation--active .wave-animation__ring--1 {
  animation: wave-ring-expand 3.2s ease-out infinite;
  animation-delay: 0s;
}

.wave-animation--active .wave-animation__ring--2 {
  animation: wave-ring-expand 3.2s ease-out infinite;
  animation-delay: 0.55s;
}

.wave-animation--active .wave-animation__ring--3 {
  animation: wave-ring-expand 3.2s ease-out infinite;
  animation-delay: 1.1s;
}

.wave-animation--active .wave-animation__ring--4 {
  animation: wave-ring-expand 3.2s ease-out infinite;
  animation-delay: 1.65s;
}

.wave-animation--active .wave-animation__ring--5 {
  animation: wave-ring-expand 3.2s ease-out infinite;
  animation-delay: 2.2s;
}

@keyframes wave-ring-expand {
  0% {
    transform: scale(0.35);
    opacity: 0.85;
    border-color: var(--ring-color);
  }
  55% {
    opacity: 0.35;
  }
  100% {
    transform: scale(4.8);
    opacity: 0;
    border-color: var(--ring-color-soft);
  }
}

@keyframes wave-breathe {
  0%,
  100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.03);
  }
}

.wave-animation__glow-core {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 120rpx;
  height: 120rpx;
  margin-left: -60rpx;
  margin-top: -60rpx;
  border-radius: 50%;
  background: radial-gradient(
    circle at 50% 45%,
    var(--glow-center) 0%,
    var(--glow-outer) 55%,
    transparent 72%
  );
  pointer-events: none;
  z-index: 1;
  animation: glow-pulse 3.6s ease-in-out infinite;
}

.wave-animation--active .wave-animation__glow-core {
  animation: glow-pulse 3.6s ease-in-out infinite;
}

.wave-animation:not(.wave-animation--active) .wave-animation__glow-core {
  animation: none;
  opacity: 0.45;
}

@keyframes glow-pulse {
  0%,
  100% {
    opacity: 0.75;
    transform: scale(1);
    filter: blur(0);
  }
  50% {
    opacity: 1;
    transform: scale(1.08);
    filter: blur(4px);
  }
}

.wave-animation__canvas {
  position: absolute;
  left: 0;
  top: 0;
  width: 420rpx;
  height: 420rpx;
  z-index: 2;
  pointer-events: none;
}

.wave-animation__status {
  margin-top: 8rpx;
  width: 100%;
  min-height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.wave-animation__status-text {
  font-size: 26rpx;
  color: var(--status-color);
  text-align: center;
  line-height: 1.45;
  letter-spacing: 0.5rpx;
  opacity: 0.92;
}

.wave-animation__status--fade-out .wave-animation__status-text {
  animation: status-fade-out 0.35s ease forwards;
}

.wave-animation__status--fade-in .wave-animation__status-text {
  animation: status-fade-in 0.45s ease forwards;
}

@keyframes status-fade-out {
  from {
    opacity: 0.92;
  }
  to {
    opacity: 0;
  }
}

@keyframes status-fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 0.92;
  }
}
