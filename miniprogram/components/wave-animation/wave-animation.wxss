/* 情绪感知态：柔波纹 · 呼吸 · 微流 · 粒子渐亮 */

.sense {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.55s ease;
}

.sense--active {
  opacity: 1;
}

.sense__vignette {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: radial-gradient(
    ellipse 85% 80% at 50% 46%,
    rgba(10, 8, 18, 0) 0%,
    rgba(10, 8, 18, 0.35) 55%,
    rgba(0, 0, 0, 0.55) 100%
  );
}

.sense__ripples {
  position: absolute;
  inset: 0;
  z-index: 2;
}

.sense__ring {
  position: absolute;
  left: 50%;
  top: 46%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border-width: 2rpx;
  border-style: solid;
  animation: sense-ripple 5.2s ease-in-out infinite;
}

.sense__ring--1 {
  width: 200rpx;
  height: 200rpx;
  animation-delay: 0s;
}

.sense__ring--2 {
  width: 290rpx;
  height: 290rpx;
  animation-delay: 0.75s;
  opacity: 0.85;
}

.sense__ring--3 {
  width: 380rpx;
  height: 380rpx;
  animation-delay: 1.45s;
  opacity: 0.72;
}

.sense__ring--4 {
  width: 470rpx;
  height: 470rpx;
  animation-delay: 2.1s;
  opacity: 0.55;
}

.sense--deep .sense__ring {
  border-color: rgba(168, 85, 247, 0.22);
}

.sense--calm .sense__ring {
  border-color: rgba(78, 205, 196, 0.2);
}

.sense--bright .sense__ring {
  border-color: rgba(255, 159, 67, 0.22);
}

@keyframes sense-ripple {
  0%,
  100% {
    transform: translate(-50%, -50%) scale(0.9);
    opacity: 0.08;
  }
  50% {
    transform: translate(-50%, -50%) scale(1.04);
    opacity: 0.34;
  }
}

.sense__core {
  position: absolute;
  left: 50%;
  top: 46%;
  z-index: 3;
  width: 240rpx;
  height: 240rpx;
  margin-left: -120rpx;
  margin-top: -120rpx;
  animation: sense-airflow 10s ease-in-out infinite;
}

@keyframes sense-airflow {
  0%,
  100% {
    transform: translate(0, 0);
  }
  28% {
    transform: translate(8rpx, -10rpx);
  }
  55% {
    transform: translate(-6rpx, 8rpx);
  }
  78% {
    transform: translate(4rpx, 5rpx);
  }
}

.sense__bloom {
  position: absolute;
  border-radius: 50%;
  animation: sense-breathe 4.8s ease-in-out infinite;
}

.sense__bloom--a {
  width: 120rpx;
  height: 120rpx;
  left: 50%;
  top: 50%;
  margin: -60rpx 0 0 -60rpx;
  animation-delay: 0s;
}

.sense__bloom--b {
  width: 160rpx;
  height: 160rpx;
  left: 50%;
  top: 50%;
  margin: -80rpx 0 0 -80rpx;
  animation-delay: 0.4s;
  opacity: 0.85;
}

.sense__bloom--c {
  width: 88rpx;
  height: 88rpx;
  left: 50%;
  top: 50%;
  margin: -44rpx 0 0 -44rpx;
  animation-delay: 0.85s;
  opacity: 0.7;
}

.sense--deep .sense__bloom--a {
  background: radial-gradient(
    circle at 42% 40%,
    rgba(255, 255, 255, 0.35) 0%,
    rgba(192, 132, 252, 0.55) 38%,
    rgba(126, 34, 206, 0.15) 65%,
    transparent 76%
  );
  box-shadow: 0 0 60rpx rgba(168, 85, 247, 0.45);
}

.sense--deep .sense__bloom--b {
  background: radial-gradient(
    circle at 55% 58%,
    rgba(216, 180, 254, 0.35) 0%,
    rgba(139, 92, 246, 0.25) 45%,
    transparent 70%
  );
}

.sense--deep .sense__bloom--c {
  background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.5) 0%, transparent 62%);
}

.sense--calm .sense__bloom--a {
  background: radial-gradient(
    circle at 42% 40%,
    rgba(255, 255, 255, 0.32) 0%,
    rgba(126, 232, 220, 0.5) 40%,
    rgba(45, 212, 191, 0.12) 68%,
    transparent 78%
  );
  box-shadow: 0 0 56rpx rgba(78, 205, 196, 0.42);
}

.sense--calm .sense__bloom--b {
  background: radial-gradient(
    circle at 55% 58%,
    rgba(167, 243, 232, 0.3) 0%,
    rgba(45, 212, 191, 0.22) 48%,
    transparent 72%
  );
}

.sense--calm .sense__bloom--c {
  background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.48) 0%, transparent 62%);
}

.sense--bright .sense__bloom--a {
  background: radial-gradient(
    circle at 42% 40%,
    rgba(255, 255, 255, 0.38) 0%,
    rgba(255, 200, 120, 0.52) 40%,
    rgba(255, 140, 50, 0.14) 68%,
    transparent 78%
  );
  box-shadow: 0 0 56rpx rgba(255, 159, 67, 0.45);
}

.sense--bright .sense__bloom--b {
  background: radial-gradient(
    circle at 55% 58%,
    rgba(255, 214, 160, 0.35) 0%,
    rgba(255, 159, 67, 0.24) 48%,
    transparent 72%
  );
}

.sense--bright .sense__bloom--c {
  background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.52) 0%, transparent 62%);
}

@keyframes sense-breathe {
  0%,
  100% {
    transform: scale(0.92);
    opacity: 0.55;
  }
  50% {
    transform: scale(1.08);
    opacity: 1;
  }
}

.sense__core-ring {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 112rpx;
  height: 112rpx;
  margin: -56rpx 0 0 -56rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  animation: sense-core-ring 2.8s ease-in-out infinite;
}

.sense--deep .sense__core-ring {
  border-color: rgba(196, 181, 253, 0.35);
  box-shadow: 0 0 28rpx rgba(168, 85, 247, 0.35);
}

.sense--calm .sense__core-ring {
  border-color: rgba(167, 243, 232, 0.3);
  box-shadow: 0 0 24rpx rgba(78, 205, 196, 0.32);
}

.sense--bright .sense__core-ring {
  border-color: rgba(255, 214, 160, 0.35);
  box-shadow: 0 0 26rpx rgba(255, 159, 67, 0.35);
}

@keyframes sense-core-ring {
  0%,
  100% {
    transform: scale(0.92);
    opacity: 0.55;
  }
  50% {
    transform: scale(1.08);
    opacity: 1;
  }
}

.sense__particle {
  position: absolute;
  z-index: 4;
  width: 6rpx;
  height: 6rpx;
  margin: -3rpx 0 0 -3rpx;
  border-radius: 50%;
  animation-name: sense-twinkle;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
}

.sense--deep .sense__particle {
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 0 14rpx rgba(216, 180, 254, 0.95), 0 0 28rpx rgba(168, 85, 247, 0.35);
}

.sense--calm .sense__particle {
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 0 12rpx rgba(186, 250, 240, 0.9), 0 0 24rpx rgba(78, 205, 196, 0.3);
}

.sense--bright .sense__particle {
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 0 12rpx rgba(255, 220, 170, 0.95), 0 0 26rpx rgba(255, 159, 67, 0.35);
}

@keyframes sense-twinkle {
  0%,
  100% {
    opacity: 0.12;
    transform: scale(0.45);
  }
  35% {
    opacity: 0.95;
    transform: scale(1);
  }
  65% {
    opacity: 0.45;
    transform: scale(0.75);
  }
}

.sense__caption {
  position: absolute;
  left: 50%;
  bottom: 8%;
  transform: translateX(-50%);
  z-index: 5;
  max-width: 88%;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 22rpx;
  line-height: 1.55;
  color: rgba(230, 228, 245, 0.42);
  text-align: center;
  letter-spacing: 0.06em;
  animation: sense-caption-breathe 4s ease-in-out infinite;
}

@keyframes sense-caption-breathe {
  0%,
  100% {
    opacity: 0.38;
  }
  50% {
    opacity: 0.72;
  }
}
