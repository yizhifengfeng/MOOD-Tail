.wave-animation {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.35s ease;
}

.wave-animation--active {
  opacity: 1;
}

.wave-animation__layer {
  position: absolute;
  left: -20%;
  width: 140%;
  height: 120rpx;
  border-radius: 50%;
  opacity: 0.35;
}

.wave-animation--calm .wave-animation__layer {
  background: linear-gradient(90deg, transparent, rgba(78, 205, 196, 0.55), transparent);
}

.wave-animation--bright .wave-animation__layer {
  background: linear-gradient(90deg, transparent, rgba(255, 159, 67, 0.55), transparent);
}

.wave-animation--deep .wave-animation__layer {
  background: linear-gradient(90deg, transparent, rgba(168, 85, 247, 0.55), transparent);
}

.wave-animation__layer--1 {
  bottom: 8%;
  animation: wave-shift 2.4s ease-in-out infinite;
}

.wave-animation__layer--2 {
  bottom: 4%;
  opacity: 0.28;
  animation: wave-shift 3.1s ease-in-out infinite reverse;
}

.wave-animation__layer--3 {
  bottom: 0;
  opacity: 0.22;
  animation: wave-shift 3.8s ease-in-out infinite;
}

@keyframes wave-shift {
  0%,
  100% {
    transform: translateX(0) scaleY(1);
  }
  50% {
    transform: translateX(6%) scaleY(1.08);
  }
}

.wave-animation__text {
  position: absolute;
  left: 50%;
  bottom: 18%;
  transform: translateX(-50%);
  max-width: 90%;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  text-align: center;
  line-height: 1.4;
}
