/* 分析态：全透明底 · 情绪色水波浪球 · 柔波纹 · 高亮粒子 */

.sense {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  overflow: visible;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.55s ease;
  background: transparent;
}

.sense--active {
  opacity: 1;
}

.sense__ripples {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.sense__ring {
  position: absolute;
  left: 50%;
  top: 46%;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border-width: 2rpx;
  border-style: solid;
  animation: sense-ripple 6.8s ease-in-out infinite;
  background: transparent;
}

.sense__ring--1 {
  width: 200rpx;
  height: 200rpx;
  animation-delay: 0s;
}

.sense__ring--2 {
  width: 290rpx;
  height: 290rpx;
  animation-delay: 0.75s;
  opacity: 0.88;
}

.sense__ring--3 {
  width: 380rpx;
  height: 380rpx;
  animation-delay: 1.45s;
  opacity: 0.76;
}

.sense__ring--4 {
  width: 470rpx;
  height: 470rpx;
  animation-delay: 2.1s;
  opacity: 0.6;
}

@keyframes sense-ripple {
  0%,
  100% {
    transform: translate(-50%, -50%) scale(0.94);
    opacity: 0.08;
  }
  50% {
    transform: translate(-50%, -50%) scale(1.02);
    opacity: 0.32;
  }
}

/* 水波浪球 */
.wave-ball-wrap {
  position: absolute;
  left: 50%;
  top: 46%;
  z-index: 4;
  width: 268rpx;
  height: 268rpx;
  margin-left: -134rpx;
  margin-top: -134rpx;
  animation: wave-ball-airflow 12s ease-in-out infinite;
}

@keyframes wave-ball-airflow {
  0%,
  100% {
    transform: translate(0, 0);
  }
  28% {
    transform: translate(5rpx, -6rpx);
  }
  55% {
    transform: translate(-4rpx, 5rpx);
  }
  78% {
    transform: translate(3rpx, 3rpx);
  }
}

.wave-ball {
  width: 268rpx;
  height: 268rpx;
  border-radius: 50%;
  position: relative;
  animation: wave-ball-breathe 4.6s ease-in-out infinite;
}

@keyframes wave-ball-breathe {
  0%,
  100% {
    transform: scale(0.96);
  }
  50% {
    transform: scale(1.05);
  }
}

.wave-ball__body {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  overflow: hidden;
}

.wave-ball__waves {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 58%;
  overflow: hidden;
  border-radius: 0 0 50% 50%;
}

.wave-ball__wave {
  position: absolute;
  left: -44%;
  width: 188%;
  height: 64rpx;
  border-radius: 50%;
  opacity: 0.82;
}

.wave-ball__wave--1 {
  bottom: 8%;
  animation: wave-surface-a 2.2s ease-in-out infinite;
}

.wave-ball__wave--2 {
  bottom: 22%;
  opacity: 0.64;
  animation: wave-surface-b 2.75s ease-in-out infinite;
  animation-delay: 0.35s;
}

.wave-ball__wave--3 {
  bottom: 36%;
  opacity: 0.52;
  animation: wave-surface-c 1.85s ease-in-out infinite;
  animation-delay: 0.15s;
}

@keyframes wave-surface-a {
  0%,
  100% {
    transform: translateX(-10%) rotate(-2deg);
  }
  50% {
    transform: translateX(12%) rotate(2deg);
  }
}

@keyframes wave-surface-b {
  0%,
  100% {
    transform: translateX(8%) translateY(4rpx);
  }
  50% {
    transform: translateX(-14%) translateY(-6rpx);
  }
}

@keyframes wave-surface-c {
  0%,
  100% {
    transform: translateX(6%) scaleX(1.04);
  }
  50% {
    transform: translateX(-11%) scaleX(0.96);
  }
}

.wave-ball__spec {
  position: absolute;
  left: 14%;
  top: 16%;
  width: 42%;
  height: 22%;
  border-radius: 50%;
  background: radial-gradient(
    ellipse at center,
    rgba(255, 255, 255, 0.65) 0%,
    rgba(255, 255, 255, 0.12) 55%,
    transparent 72%
  );
  pointer-events: none;
  z-index: 4;
  animation: wave-spec-drift 6s ease-in-out infinite;
}

@keyframes wave-spec-drift {
  0%,
  100% {
    opacity: 0.85;
    transform: translate(0, 0);
  }
  50% {
    opacity: 1;
    transform: translate(4rpx, 3rpx);
  }
}

/* 背景粒子：更大、更亮，颜色由内联 style 绑定情绪色 */
.sense__particle {
  position: absolute;
  z-index: 2;
  width: 9rpx;
  height: 9rpx;
  margin: -4.5rpx 0 0 -4.5rpx;
  border-radius: 50%;
  animation-name: sense-twinkle;
  animation-timing-function: ease-in-out;
  animation-iteration-count: infinite;
}

@keyframes sense-twinkle {
  0%,
  100% {
    opacity: 0.35;
    transform: scale(0.55);
  }
  42% {
    opacity: 1;
    transform: scale(1);
  }
  68% {
    opacity: 0.55;
    transform: scale(0.88);
  }
}

.sense__caption {
  position: absolute;
  left: 50%;
  bottom: 6%;
  transform: translateX(-50%);
  z-index: 5;
  max-width: 88%;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 22rpx;
  line-height: 1.55;
  color: rgba(235, 233, 250, 0.72);
  text-align: center;
  letter-spacing: 0.06em;
  text-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.35);
  animation: sense-caption-breathe 4s ease-in-out infinite;
}

@keyframes sense-caption-breathe {
  0%,
  100% {
    opacity: 0.55;
  }
  50% {
    opacity: 0.92;
  }
}
