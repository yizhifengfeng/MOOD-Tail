/* Mood palette: bright / calm / deep */
.mood-calendar {
  box-sizing: border-box;
  padding: 24rpx 20rpx 28rpx;
  background: linear-gradient(165deg, #14141c 0%, #0c0c12 48%, #101018 100%);
  border-radius: 24rpx;
  color: rgba(255, 255, 255, 0.92);
}

.mood-calendar__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.mood-calendar__title-wrap {
  flex: 1;
  text-align: center;
}

.mood-calendar__title {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: rgba(255, 255, 255, 0.95);
}

.mood-calendar__nav {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  transition: background 0.2s ease, transform 0.15s ease;
}

.mood-calendar__nav--active {
  background: rgba(255, 255, 255, 0.12);
  transform: scale(0.96);
}

.mood-calendar__arrow {
  font-size: 44rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.75);
  font-weight: 300;
}

.mood-calendar__weekdays {
  display: grid;
  grid-template-columns: repeat(7, 80rpx);
  gap: 12rpx;
  justify-content: center;
  margin-bottom: 12rpx;
  padding: 0 4rpx;
}

.mood-calendar__weekday {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.38);
  letter-spacing: 0.04em;
}

.mood-calendar__grid {
  display: grid;
  grid-template-columns: repeat(7, 80rpx);
  grid-template-rows: repeat(6, 80rpx);
  gap: 12rpx;
  padding: 8rpx 4rpx 4rpx;
  justify-content: center;
  transition: opacity 0.28s ease;
}

.mood-calendar__cell {
  box-sizing: border-box;
  width: 80rpx;
  height: 80rpx;
  border-radius: 18rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mood-calendar__cell--empty {
  background: transparent;
  pointer-events: none;
}

.mood-calendar__cell--day {
  background: rgba(255, 255, 255, 0.04);
  transition: background 0.22s ease, box-shadow 0.22s ease, transform 0.18s ease;
}

.mood-calendar__cell--day:active {
  transform: scale(0.94);
}

/* Mood fills */
.mood-calendar__cell--day.mood-bright {
  background: rgba(255, 159, 67, 0.38);
  box-shadow: 0 0 0 1rpx rgba(255, 159, 67, 0.25);
}

.mood-calendar__cell--day.mood-calm {
  background: rgba(78, 205, 196, 0.36);
  box-shadow: 0 0 0 1rpx rgba(78, 205, 196, 0.22);
}

.mood-calendar__cell--day.mood-deep {
  background: rgba(168, 85, 247, 0.38);
  box-shadow: 0 0 0 1rpx rgba(168, 85, 247, 0.25);
}

.mood-calendar__glow {
  position: absolute;
  inset: 4rpx;
  border-radius: 14rpx;
  pointer-events: none;
  box-shadow: 0 0 18rpx rgba(255, 255, 255, 0.22);
  opacity: 0.55;
}

.mood-calendar__cell--day.mood-bright .mood-calendar__glow {
  box-shadow: 0 0 22rpx rgba(255, 159, 67, 0.55);
}

.mood-calendar__cell--day.mood-calm .mood-calendar__glow {
  box-shadow: 0 0 22rpx rgba(78, 205, 196, 0.5);
}

.mood-calendar__cell--day.mood-deep .mood-calendar__glow {
  box-shadow: 0 0 22rpx rgba(168, 85, 247, 0.55);
}

.mood-calendar__day-num {
  position: relative;
  z-index: 1;
  font-size: 26rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.92);
}

/* Today ring */
.mood-calendar__cell--day.cell-today {
  box-shadow: 0 0 0 3rpx rgba(255, 255, 255, 0.85), 0 0 20rpx rgba(255, 255, 255, 0.15);
}

.mood-calendar__cell--day.cell-today.mood-bright {
  box-shadow: 0 0 0 3rpx rgba(255, 200, 140, 0.95), 0 0 24rpx rgba(255, 159, 67, 0.45);
}

.mood-calendar__cell--day.cell-today.mood-calm {
  box-shadow: 0 0 0 3rpx rgba(160, 235, 228, 0.95), 0 0 24rpx rgba(78, 205, 196, 0.4);
}

.mood-calendar__cell--day.cell-today.mood-deep {
  box-shadow: 0 0 0 3rpx rgba(210, 180, 255, 0.95), 0 0 24rpx rgba(168, 85, 247, 0.45);
}
